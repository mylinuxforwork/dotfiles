#!/usr/bin/env bash
#    _____    __                 __
#   / __(_)__/ /__ ___  ___ ____/ /
#  _\ \/ / _  / -_) _ \/ _ `/ _  / 
# /___/_/\_,_/\__/ .__/\_,_/\_,_/  
#               /_/                
# Dispatcher

# -----------------------------------------------------
# Load Launcher
# -----------------------------------------------------
launcher=$(cat "$HOME/.config/ml4w/settings/launcher")

# Configuration
SIDEPAD_PATH="$HOME/.config/sidepad/sidepad"
SIDEPAD_DATA="$HOME/.config/ml4w/settings/sidepad-active"
SIDEPAD_POS_FILE="$HOME/.config/ml4w/settings/sidepad-position"
SIDEPAD_PADS_FOLDER="$HOME/.config/sidepad/pads"
SIDEPAD_SELECT="$HOME/.config/sidepad/scripts/select.sh"

# Load active sidepad
SIDEPAD_OPTIONS=(--width 900 --width-max 1200)

if [ ! -f "$SIDEPAD_DATA" ]; then
    echo "Error: Sidepad data file not found at $SIDEPAD_DATA"
    exit 1
fi
SIDEPAD_ACTIVE=$(cat "$SIDEPAD_DATA")

if [ -f "$SIDEPAD_POS_FILE" ]; then
    SIDEPAD_POS=$(cat "$SIDEPAD_POS_FILE")
else
    SIDEPAD_POS="left"
fi

ACTIVE_PAD_FILE="$SIDEPAD_PADS_FOLDER/$SIDEPAD_ACTIVE"
if [ ! -f "$ACTIVE_PAD_FILE" ]; then
    echo "Error: Active sidepad file not found at $ACTIVE_PAD_FILE"
    exit 1
fi
source "$ACTIVE_PAD_FILE"

echo ":: Current sidepad: $SIDEPAD_ACTIVE"
echo ":: Current sidepad app: $SIDEPAD_APP"
echo ":: Current sidepad class: $SIDEPAD_CLASS"
echo ":: Current sidepad position: $SIDEPAD_POS"

# Check if sidepad window exists
is_sidepad_running() {
    hyprctl clients -j | jq -e --arg class "$SIDEPAD_CLASS" '.[] | select(.class == $class)' > /dev/null
    return $?
}

# Check if sidepad is visible (works for both left and right positions)
is_sidepad_visible() {
    local window_info
    window_info=$(hyprctl clients -j | jq --arg class "$SIDEPAD_CLASS" '.[] | select(.class == $class)')

    if [ -z "$window_info" ]; then
        return 1
    fi

    local window_x
    local window_width
    local monitor_info
    local monitor_x
    local monitor_width

    window_x=$(echo "$window_info" | jq -r '.at[0]')
    window_width=$(echo "$window_info" | jq -r '.size[0]')
    monitor_info=$(hyprctl monitors -j | jq '.[] | select(.focused == true)')
    monitor_x=$(echo "$monitor_info" | jq -r '.x')
    monitor_width=$(echo "$monitor_info" | jq -r '.width')

    if [ -z "$window_x" ] || [ "$window_x" == "null" ]; then
        return 1
    fi

    if [[ "$SIDEPAD_POS" == "right" ]]; then
        if (( window_x <= monitor_x + monitor_width - window_width )); then
            return 0
        fi
    else
        if (( window_x >= monitor_x )); then
            return 0
        fi
    fi

    return 1
}

# Select new sidepad with rofi
select_sidepad() {
    # Open rofi
    if [ "$launcher" == "walker" ]; then
        pad=$(ls "$SIDEPAD_PADS_FOLDER" | "$HOME/.config/walker/launch.sh" -d -n -N -H --maxheight 400 -p "Sidepads")
    else
        pad=$(ls "$SIDEPAD_PADS_FOLDER" | rofi -dmenu -replace -i -config ~/.config/rofi/config-compact.rasi -no-show-icons -width 30 -p "Sidepads")
    fi

    # Set new sidepad
    if [[ -n "$pad" ]]; then
        echo ":: New sidepad: $pad"

        # Kill existing sidepad
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --kill

        # Write pad into active data file
        echo "$pad" > "$SIDEPAD_DATA"
        SIDEPAD_ACTIVE=$(cat "$SIDEPAD_DATA")

        # Init sidepad
        NEW_PAD_FILE="$SIDEPAD_PADS_FOLDER/$pad"
        if [ ! -f "$NEW_PAD_FILE" ]; then
            echo "Error: Selected sidepad file not found at $NEW_PAD_FILE"
            return 1
        fi

        source "$NEW_PAD_FILE"
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --init "$SIDEPAD_APP"
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" "${SIDEPAD_OPTIONS[@]}"
        echo ":: Sidepad switched"
    fi
}

# Switch sidepad position (left <-> right)
switch_side() {
    local new_pos
    if [[ "$SIDEPAD_POS" == "left" ]]; then
        new_pos="right"
    else
        new_pos="left"
    fi

    echo ":: Switching sidepad from $SIDEPAD_POS to $new_pos"

    if is_sidepad_running; then
        "$SIDEPAD_PATH" --position "$new_pos" --class "$SIDEPAD_CLASS" "${SIDEPAD_OPTIONS[@]}"
    fi

    echo "$new_pos" > "$SIDEPAD_POS_FILE"
    SIDEPAD_POS="$new_pos"
    echo ":: Sidepad switched to $new_pos"
}

# Dispatch parameters
if [[ "$1" == "--init" ]]; then
    if ! is_sidepad_running; then
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --init "$SIDEPAD_APP"
    fi
    "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" "${SIDEPAD_OPTIONS[@]}"

elif [[ "$1" == "--hide" ]]; then
    "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --hide

elif [[ "$1" == "--toggle" ]]; then
    if ! is_sidepad_running; then
        echo ":: Sidepad not running, initializing..."
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --init "$SIDEPAD_APP"
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" "${SIDEPAD_OPTIONS[@]}"
    elif is_sidepad_visible; then
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --hide
    else
        "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" "${SIDEPAD_OPTIONS[@]}"
    fi

elif [[ "$1" == "--test" ]]; then
    "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --test

elif [[ "$1" == "--kill" ]]; then
    "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --kill

elif [[ "$1" == "--switch-side" ]]; then
    switch_side

elif [[ "$1" == "--select" ]]; then
    select_sidepad

else
    "$SIDEPAD_PATH" --position "$SIDEPAD_POS" --class "$SIDEPAD_CLASS" --toggle
fi
