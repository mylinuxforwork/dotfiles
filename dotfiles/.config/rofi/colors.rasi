    secondary-fixed-dim: #b1cbce;
    on-secondary: #1c3437;
    on-secondary-fixed: #051f22;
    on-secondary-fixed-variant: #324b4d;
    secondary-container: #324b4d;
    on-secondary-container: #cce8ea;
    tertiary: #b8c6ea;
