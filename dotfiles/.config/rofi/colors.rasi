    error-container: #93000a;
    on-error-container: #ffdad6;
    surface: #0e1415;
    on-surface: #dee4e4;
    on-surface-variant: #bec8c9;
    outline: #899394;
    outline-variant: #3f4849;
    shadow: #000000;
    scrim: #000000;
    inverse-surface: #dee4e4;
    inverse-on-surface: #2b3232;
    inverse-primary: #006971;
    surface-dim: #0e1415;
    surface-bright: #343a3b;
