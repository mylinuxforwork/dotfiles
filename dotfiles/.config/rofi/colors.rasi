    tertiary-fixed-dim: #b8c6ea;
    on-tertiary: #21304c;
    on-tertiary-fixed: #0b1b36;
    on-tertiary-fixed-variant: #384764;
    tertiary-container: #384764;
    on-tertiary-container: #d7e2ff;
